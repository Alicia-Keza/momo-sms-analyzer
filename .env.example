#.env.example -a template for environment variables
#this file is committed so others can know which variables to set
#copy it to .env and fill in your real value, then export them in yout shell:
#copy .env.example to .env
#set -a; source .env; set +a
#python -m api.server

#Do not commit .env to git , it lives in .gitignore for a reason

#Username required to authenticate against the API
API_USERNAME=admin

#password paired with API_USERNAME for authentication
API_PASSWORD=password123

#port the API server listens on
API_PORT=8000
